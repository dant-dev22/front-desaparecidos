# Backend público en producción (FastAPI: /locations, /risk).
VITE_API_BASE_URL=https://estoyasalvo.com

# Vacío = el navegador llama directo a VITE_API_BASE_URL (requiere CORS abierto en el servidor).
# Para desarrollo sin preflight, puedes usar la fila comentada siguiente y dejar VITE_API_PREFIX=/api.
VITE_API_PREFIX=

# Desarrollo opcional: proxy de Vite reenvía /api → VITE_API_BASE_URL (solo con npm run dev).
# VITE_API_PREFIX=/api

# Backend local (si quieres usarlo en vez de estoyasalvo.com):
# VITE_API_BASE_URL=http://127.0.0.1:8000
# Con proxy en dev: VITE_API_PREFIX=/api
